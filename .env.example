# =====================================================
# ЭНЭХҮҮ ФАЙЛЫГ .env гэж нэрлэж хадгална уу
# ХЭЗЭЭ Ч GitHub-д оруулж болохгүй!
# =====================================================

# Facebook хуудасны Access Token
# (Facebook Developer Console -> Messenger -> Access Tokens)
PAGE_ACCESS_TOKEN=your_page_access_token_here

# Verify Token — та өөрөө зохиосон дурын нууц үг
# (Facebook webhook бүртгэхдээ энэ утгыг оруулна)
VERIFY_TOKEN=mini_sain_nuuts_ug_1234

# Claude API түлхүүр
# (console.anthropic.com дээрээс авна)
CLAUDE_API_KEY=your_claude_api_key_here

# Server port (Railway/Render автоматаар тохируулна)
PORT=3000
